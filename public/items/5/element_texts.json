[{"name":"Dublin Core","elements":[{"name":"Title","texts":["St. Patrick's well at Tullaghan"]},{"name":"Subject","texts":["Lough Derg--Folklore--Holy Well--Tullaghan"]},{"name":"Description","texts":["\"St. Patrick\u2019s Well at Tullaghan has a legend. St Patrick stopped the night in a house near a mountain. The woman told him not to look at the light on the mountain, but he went up and saw a serpent and when he struck it, St. Patrick\u2019s Well sprang up. He killed it at Lough Derg and its blood gave the Lough its colour.\""]},{"name":"Creator","texts":["Si\u00faracha Naomh Lughbhaidh"]},{"name":"Source","texts":["The Schools\u2019 Collection, Volume 1026, Page 024"]},{"name":"Publisher","texts":["National Folklore Collection, UCD"]},{"name":"Date","texts":["1937-39"]},{"name":"Contributor","texts":["duchas.ie, hosting and crowd-sourced transcription"]},{"name":"Rights","texts":["CC BY-NC 4.0 International License"]},{"name":"Format","texts":["Transcribed text and digitised manuscript"]},{"name":"Language","texts":["English"]},{"name":"Type","texts":["Oral history, folklore","Oral History"]},{"name":"Identifier","texts":["DD_0005"]},{"name":"Coverage","texts":["\r\n54.469479, -8.329220"]},{"name":"References","texts":["https:\/\/www.duchas.ie\/en\/cbes\/4428247\/4388240\/4455986"]}]},{"name":"Oral History Item Type Metadata","elements":[{"name":"Interviewee","texts":["Si\u00faracha Naomh Lughbhaidh"]},{"name":"Location","texts":["Bundoran, County Donegal"]},{"name":"Transcription","texts":["Crowd-sourced transcription (English)"]}]}]