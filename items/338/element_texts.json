[{"name":"Dublin Core","elements":[{"name":"Title","texts":["The Friary"]},{"name":"Subject","texts":["Lough Derg--Vicinity--Lough Eske--Friars"]},{"name":"Description","texts":["\"The Friary is a townland on Killymard ([Cill O mB\u00e1rd]) side of Lough Eske. It was here the Friars settled when banished from Donegal and ministered to the spiritual wants of the neigh-bouring districts.\r\n\r\nThere is now no sign of a church or building there but Tobar na mBrathar agus Rois\u00edn as well as Droichead na mbr\u00e1thar and Cas\u00e1n na mbr\u00e1thar all close by, seem to be associated with their activities here.\""]},{"name":"Creator","texts":["Adhamhnan Mag Fhionntaigh"]},{"name":"Source","texts":["The Schools\u2019 Collection, Volume 1035, Page 178"]},{"name":"Publisher","texts":["National Folklore Collection, UCD"]},{"name":"Date","texts":["1937-39"]},{"name":"Contributor","texts":["duchas.ie, hosting and crowd-sourced transcription"]},{"name":"Rights","texts":["CC BY-NC 4.0 International License"]},{"name":"Format","texts":["Transcribed text and digitised manuscript"]},{"name":"Language","texts":["English"]},{"name":"Type","texts":["Oral history, folklore"]},{"name":"Identifier","texts":["DD_0318"]},{"name":"Coverage","texts":["54.703737,-8.060909"]},{"name":"References","texts":["https:\/\/www.duchas.ie\/en\/cbes\/4428281\/4391418\/4478771"]}]},{"name":"Oral History Item Type Metadata","elements":[{"name":"Interviewer","texts":["Adhamhnan Mag Fhionntaigh, age 13"]},{"name":"Location","texts":["Friary, Co. Donegal"]},{"name":"Transcription","texts":["Crowd-sourced transcription (English)"]}]}]